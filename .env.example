# Copy this file to .env and fill in real values.
# Both frontend (Next.js) and backend (FastAPI) read from this single file.

# --- Frontend (exposed to browser; NEXT_PUBLIC_ prefix required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend (server-only; never exposed to browser) ---
CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# Set to https://eu.api.smith.langchain.com if your LangSmith workspace is in
# the EU region. Leave blank for the default US region.
LANGSMITH_ENDPOINT=

# --- Google Cloud (Module 1.5 RAG migration) ---
GCP_PROJECT_ID=
# Absolute path to the service-account JSON key (kept outside the repo).
GCP_SERVICE_ACCOUNT_JSON_PATH=
DOCUMENTAI_LOCATION=eu
DOCUMENTAI_PROCESSOR_ID=
GCS_STAGING_BUCKET=

# --- Vertex AI RAG Engine (plan 18.x migration) ---
# Region for the corpus, GCS bucket, embedding model, and Gemini calls.
GCP_LOCATION=europe-west3
# Bucket holding both ingestion sources and permanent original files.
GCS_FILES_BUCKET=sleek-rag-files-dev
VERTEX_RAG_EMBEDDING_MODEL=text-embedding-005
VERTEX_RAG_EMBEDDING_DIM=768
VERTEX_RAG_GENERATION_MODEL=gemini-2.5-pro
VERTEX_RAG_PARSING_MODEL=gemini-2.5-pro
# Region for the parsing model. Gemini 2.5 Pro is not published in
# europe-west3, so the LLM Parser must reference a region that has it
# (e.g. "global", "us-central1"). Independent of the corpus region.
VERTEX_RAG_PARSING_MODEL_LOCATION=global
VERTEX_RAG_PARSING_MAX_REQUESTS_PER_MIN=10

# --- Gemini API (OpenAI-compatible endpoint) ---
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# --- Retrieval (plan 16: hybrid + rerank) ---
# RETRIEVAL_MODE=hybrid is the default; set to "vector_only" to disable the
# FTS channel + Vertex AI rerank and reproduce plan-14 behavior.
RETRIEVAL_MODE=hybrid
PRE_RERANK_K=30
RERANK_MODEL=semantic-ranker-default-004
RERANK_TIMEOUT_SEC=4.0
PROJEKTANALYSE_TOP_K=15
PROJEKTANALYSE_PRE_RERANK_K=80