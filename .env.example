# Copy this file to .env and fill in real values.
# Both frontend (Next.js) and backend (FastAPI) read from this single file.

# --- Frontend (exposed to browser; NEXT_PUBLIC_ prefix required) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend (server-only; never exposed to browser) ---
CORS_ORIGINS=http://localhost:3000

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=
# Set to https://eu.api.smith.langchain.com if your LangSmith workspace is in
# the EU region. Leave blank for the default US region.
LANGSMITH_ENDPOINT=

# --- Google Cloud ---
GCP_PROJECT_ID=
# Absolute path to the service-account JSON key (kept outside the repo).
GCP_SERVICE_ACCOUNT_JSON_PATH=
GCS_STAGING_BUCKET=

# --- Vertex AI RAG Engine — Serverless mode (plan 20.0) ---
# us-central1 only — serverless preview is restricted to this region.
GCP_LOCATION=us-central1
# Bucket holding ingestion sources + permanent originals (must be in GCP_LOCATION).
GCS_FILES_BUCKET=sleek-rag-files-us-dev
# Document AI Layout Parser processor backing the corpus's import.
# Multi-region "us" works for any us-* corpus.
DOCUMENTAI_US_LOCATION=us
DOCUMENTAI_US_PROCESSOR_ID=452479dfc534f517
# Embedding model used by the corpus's RagManagedVertexVectorSearch.
# Vertex RAG allowlists a subset; text-multilingual-embedding-002 fits the
# German corpora best. Other valid picks: text-embedding-005,
# gemini-embedding-001, text-embedding-large-exp-03-07.
VERTEX_RAG_EMBEDDING_MODEL=text-multilingual-embedding-002

# --- Gemini API (OpenAI-compatible endpoint) ---
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768